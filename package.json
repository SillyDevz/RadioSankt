{
  "name": "radio-sankt",
  "version": "1.0.18",
  "description": "Radio Sankt",
  "main": "dist/main/index.js",
  "scripts": {
    "prepare": "husky",
    "postinstall": "node ./scripts/repair-electron-mac-framework.cjs",
    "check:secrets": "node ./scripts/check-secrets.cjs",
    "start": "npm run electron:dev",
    "dev": "vite",
    "build": "tsc && vite build",
    "build:electron": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "icons:generate": "node ./scripts/rasterize-app-icon.cjs",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build && npm run build:electron && npx @electron/rebuild && electron-builder",
    "electron:build:win": "npm run build && npm run build:electron && npx @electron/rebuild && electron-builder --win",
    "electron:build:mac": "npm run build && npm run build:electron && npx @electron/rebuild && electron-builder --mac",
    "preview": "vite preview",
    "i18n:check": "node ./scripts/check-i18n.cjs",
    "check:version-bump": "node ./scripts/check-version-bump.cjs",
    "check:release-tag": "node ./scripts/check-release-tag.cjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/react": "^0.26.0",
    "better-sqlite3": "^12.8.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "i18next": "^26.0.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.3",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.2.1",
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "github:castlabs/electron-releases#v41.1.1+wvcus",
    "electron-builder": "^24.9.0",
    "husky": "^9.1.7",
    "postcss": "^8.4.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
