{
  "name": "radio-sankt",
  "version": "0.1.0",
  "description": "Radio Sankt",
  "main": "dist/main/index.js",
  "scripts": {
    "postinstall": "node ./scripts/repair-electron-mac-framework.cjs",
    "dev": "vite",
    "build": "tsc && vite build",
    "build:electron": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "evs:sign-electron-dist": "python3 -m castlabs_evs.vmp sign-pkg node_modules/electron/dist",
    "evs:verify-electron-dist": "python3 -m castlabs_evs.vmp verify-pkg node_modules/electron/dist",
    "evs:sign-release": "node ./scripts/evs-sign-release.cjs",
    "electron:build": "npm run build && npm run build:electron && npx @electron/rebuild && electron-builder",
    "electron:build:evs": "npm run electron:build && npm run evs:sign-release",
    "electron:build:win": "npm run build && npm run build:electron && npx @electron/rebuild && electron-builder --win",
    "electron:build:win:evs": "npm run electron:build:win && npm run evs:sign-release",
    "electron:build:mac": "npm run build && npm run build:electron && npx @electron/rebuild && electron-builder --mac",
    "electron:build:mac:evs": "npm run electron:build:mac && npm run evs:sign-release",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/react": "^0.26.0",
    "better-sqlite3": "^12.8.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "github:castlabs/electron-releases#v41.1.1+wvcus",
    "electron-builder": "^24.9.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
